{
  "name": "rsm-decky",
  "version": "0.1.2",
  "description": "Decky plugin for per-game ReShade, shader repository, and add-on management.",
  "type": "module",
  "scripts": {
    "build": "rollup -c",
    "watch": "rollup -c -w",
    "test": "echo \"Error: no test specified\" && exit 1",
    "install:decky": "bash scripts/install-local.sh",
    "build:release": "bash scripts/build-release.sh"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zany130/RSM-Decky.git"
  },
  "keywords": [
    "decky",
    "plugin",
    "steam-deck",
    "reshade",
    "shader",
    "addons"
  ],
  "author": "zany130",
  "license": "BSD-3-Clause",
  "bugs": {
    "url": "https://github.com/zany130/RSM-Decky/issues"
  },
  "homepage": "https://github.com/zany130/RSM-Decky#readme",
  "devDependencies": {
    "@decky/rollup": "^1.0.2",
    "@decky/ui": "^4.11.0",
    "@rollup/rollup-linux-x64-musl": "^4.53.3",
    "@types/react": "19.1.1",
    "@types/react-dom": "19.1.1",
    "@types/webpack": "^5.28.5",
    "rollup": "^4.53.3",
    "typescript": "^5.6.2"
  },
  "dependencies": {
    "@decky/api": "^1.1.3",
    "react-icons": "^5.3.0",
    "tslib": "^2.7.0"
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": [
        "react",
        "react-dom"
      ]
    }
  }
}
